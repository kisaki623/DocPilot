# Generic local template for DocPilot backend.
# Recommended for quick local demo with docker-compose.demo.yml.
# For cloud middleware mode, copy backend/.env.cloud.example instead.

SPRING_PROFILES_ACTIVE=local
SERVER_PORT=8081

# MySQL (local compose)
MYSQL_HOST=127.0.0.1
MYSQL_PORT=3306
MYSQL_DATABASE=docpilot
MYSQL_DB=docpilot
MYSQL_USERNAME=docpilot
MYSQL_PASSWORD=docpilot

# Redis (local compose)
REDIS_HOST=127.0.0.1
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DATABASE=0
APP_REDIS_KEY_PREFIX=docpilot:

# RocketMQ (local compose)
ROCKETMQ_ENABLED=true
ROCKETMQ_NAME_SERVER=127.0.0.1:9876
ROCKETMQ_PRODUCER_GROUP=docpilot-producer-group
ROCKETMQ_CONSUMER_GROUP=docpilot-parse-consumer-group
DOCPILOT_PARSE_TOPIC=docpilot-parse-topic

# Storage
FILE_STORAGE_MODE=minio
FILE_UPLOAD_DIR=./data/uploads-local
FILE_CHUNK_TEMP_DIR=./data/upload-chunks-local
FILE_CHUNK_SESSION_TTL_SECONDS=86400
MINIO_ENDPOINT=http://127.0.0.1:9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin
MINIO_BUCKET=docpilot
MINIO_BASE_PATH=uploads

# AI
AI_MODE=mock
AI_MAX_DOCUMENT_CONTEXT_LENGTH=4000
AI_SESSION_CONTEXT_MAX_TURNS=6
AI_SESSION_CONTEXT_TTL_SECONDS=1800
AI_SESSION_CONTEXT_MAX_CHARS=1200
AI_REAL_PROVIDER=openai-compatible
AI_REAL_BASE_URL=https://api.openai.com/v1
AI_REAL_API_KEY=__REPLACE_WITH_YOUR_AI_API_KEY__
AI_REAL_MODEL=gpt-4o-mini
AI_REAL_CONNECT_TIMEOUT_MS=2000
AI_REAL_READ_TIMEOUT_MS=8000
AI_REAL_TEMPERATURE=0.2
AI_REAL_MAX_OUTPUT_TOKENS=800
AI_REAL_INPUT_COST_PER_1K_USD=0
AI_REAL_OUTPUT_COST_PER_1K_USD=0

# Retry / outbox / lock
AI_RETRY_ENABLED=true
AI_RETRY_MAX_ATTEMPTS=3
AI_RETRY_INITIAL_BACKOFF_MS=120
AI_RETRY_BACKOFF_MULTIPLIER=2.0
AI_RETRY_MAX_BACKOFF_MS=800
ROCKETMQ_OUTBOX_SCAN_FIXED_DELAY_MS=15000
ROCKETMQ_OUTBOX_SCAN_BATCH_SIZE=20
ROCKETMQ_OUTBOX_RETRY_BACKOFF_SECONDS=30
ROCKETMQ_OUTBOX_MAX_RETRY_COUNT=20
REDISSON_LOCK_WATCHDOG_TIMEOUT_MS=30000
REDISSON_PARSE_TASK_LOCK_FAIL_MESSAGE=当前文档解析任务处理中，请稍后重试
