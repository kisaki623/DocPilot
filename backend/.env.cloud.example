# Cloud middleware profile for local IDEA startup.
# Copy to backend/.env.cloud and fill real secrets locally only.
# Never commit backend/.env.cloud with real credentials.

SPRING_PROFILES_ACTIVE=local
SERVER_PORT=8081

MYSQL_HOST=116.204.132.136
MYSQL_PORT=3306
MYSQL_DATABASE=docpilot
MYSQL_DB=docpilot
MYSQL_USERNAME=docpilot_user
MYSQL_PASSWORD=__REPLACE_WITH_YOUR_MYSQL_PASSWORD__

REDIS_HOST=116.204.132.136
REDIS_PORT=6379
REDIS_PASSWORD=__REPLACE_WITH_YOUR_REDIS_PASSWORD__
REDIS_DATABASE=0
APP_REDIS_KEY_PREFIX=docpilot:

# For first startup verification in cloud mode, keep optional dependencies conservative.
# Enable one by one after backend boots successfully.
ROCKETMQ_ENABLED=false
ROCKETMQ_NAME_SERVER=116.204.132.136:9876
ROCKETMQ_PRODUCER_GROUP=docpilot-producer-group
ROCKETMQ_CONSUMER_GROUP=docpilot-parse-consumer-group
DOCPILOT_PARSE_TOPIC=docpilot-parse-topic

FILE_STORAGE_MODE=local
FILE_UPLOAD_DIR=./data/uploads-local
FILE_CHUNK_TEMP_DIR=./data/upload-chunks-local
FILE_CHUNK_SESSION_TTL_SECONDS=86400
MINIO_ENDPOINT=http://116.204.132.136:9000
MINIO_ACCESS_KEY=__REPLACE_WITH_YOUR_MINIO_ACCESS_KEY__
MINIO_SECRET_KEY=__REPLACE_WITH_YOUR_MINIO_SECRET_KEY__
MINIO_BUCKET=docpilot
MINIO_BASE_PATH=uploads

AI_MODE=mock
AI_MAX_DOCUMENT_CONTEXT_LENGTH=4000
AI_SESSION_CONTEXT_MAX_TURNS=6
AI_SESSION_CONTEXT_TTL_SECONDS=1800
AI_SESSION_CONTEXT_MAX_CHARS=1200
